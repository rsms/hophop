#!/usr/bin/env python3
import pathlib
import shutil
import subprocess
import sys
from typing import List


def run(cmd: List[str], cwd: pathlib.Path, check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd,
        cwd=str(cwd),
        check=check,
    )


def detect_repo_root(cwd: pathlib.Path) -> pathlib.Path:
    p = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        cwd=str(cwd),
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if p.returncode != 0 or not p.stdout:
        return cwd
    return pathlib.Path(p.stdout.strip()).resolve()


def announce(repo_root: pathlib.Path, message: str) -> None:
    tool = repo_root / "tools" / "agent-worklog"
    if not tool.is_file():
        return
    run([str(tool), "--peek", message], cwd=repo_root, check=False)


def main(argv: List[str]) -> int:
    if not shutil.which("wt"):
        print("worktrunk CLI not found on PATH (expected `wt`)", file=sys.stderr)
        return 127

    cwd = pathlib.Path.cwd().resolve()
    repo_root = detect_repo_root(cwd)
    announce(repo_root, "merge-worktree: delegating to wt merge")
    print("tools/agent-merge-worktree is deprecated; running `wt merge`", file=sys.stderr)

    p = run(["wt", "merge", *argv], cwd=cwd, check=False)
    return p.returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
