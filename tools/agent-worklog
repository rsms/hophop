#!/usr/bin/env python3
import argparse
import datetime as dt
import fcntl
import hashlib
import json
import os
import pathlib
import subprocess
import sys
import time
from dataclasses import dataclass
from typing import Dict, Iterable, List, Optional, Set, Tuple


STATE_FILENAME = ".agent-worklog-state.json"
LOG_FILENAME = ".agent-worklog.jsonl"


def run_git(args: List[str], cwd: Optional[pathlib.Path] = None, check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", *args],
        cwd=str(cwd) if cwd else None,
        check=check,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )


def detect_repo_root(cwd: pathlib.Path) -> pathlib.Path:
    p = run_git(["rev-parse", "--show-toplevel"], cwd=cwd, check=False)
    if p.returncode != 0:
        return cwd
    out = p.stdout.strip()
    if not out:
        return cwd
    return pathlib.Path(out).resolve()


def detect_git_dir(cwd: pathlib.Path) -> pathlib.Path:
    p = run_git(["rev-parse", "--git-dir"], cwd=cwd, check=False)
    if p.returncode != 0:
        return (cwd / ".git").resolve()
    out = p.stdout.strip()
    if not out:
        return (cwd / ".git").resolve()
    git_dir = pathlib.Path(out)
    if not git_dir.is_absolute():
        git_dir = (cwd / git_dir).resolve()
    return git_dir.resolve()


def detect_branch(cwd: pathlib.Path) -> str:
    p = run_git(["branch", "--show-current"], cwd=cwd, check=False)
    if p.returncode == 0:
        branch = p.stdout.strip()
        if branch:
            return branch
    p = run_git(["rev-parse", "--short", "HEAD"], cwd=cwd, check=False)
    if p.returncode == 0:
        commit = p.stdout.strip()
        if commit:
            return f"detached-{commit}"
    return "detached"


def now_iso_utc() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_iso_ts(value: str) -> dt.datetime:
    v = value.strip()
    if v.endswith("Z"):
        d = dt.datetime.fromisoformat(v[:-1])
        if d.tzinfo is None:
            d = d.replace(tzinfo=dt.timezone.utc)
    else:
        d = dt.datetime.fromisoformat(v)
    if d.tzinfo is None:
        d = d.replace(tzinfo=dt.timezone.utc)
    return d.astimezone(dt.timezone.utc)


def parse_cli(argv: List[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Append local worklog announcements and read updates from other git worktrees."
    )
    p.add_argument("--peek", action="store_true", help="Read updates without advancing read cursors.")
    p.add_argument("--since", metavar="TIMESTAMP", help="Read all messages since ISO timestamp (e.g. 2026-02-21T20:00:00Z).")
    p.add_argument(
        "--from",
        dest="from_agents",
        action="append",
        default=[],
        metavar="AGENT",
        help="Only read updates from specific agent names/branches. Repeatable; also accepts comma-separated list.",
    )
    p.add_argument("announcements", nargs="*", help="Announcement text or JSON object.")
    args = p.parse_args(argv)
    if args.since:
        try:
            args.since_dt = parse_iso_ts(args.since)
        except ValueError:
            p.error(f"invalid --since timestamp: {args.since!r}")
    else:
        args.since_dt = None
    return args


def normalize_from_agents(values: List[str]) -> Set[str]:
    out: Set[str] = set()
    for raw in values:
        for token in raw.split(","):
            name = token.strip()
            if name:
                out.add(name)
    return out


def normalize_announcement(raw: str, from_branch: str) -> Dict[str, object]:
    try:
        obj = json.loads(raw)
        if not isinstance(obj, dict):
            raise ValueError("announcement must be a JSON object")
    except Exception:
        obj = {"message": raw}
    if "timestamp" not in obj and "ts" not in obj:
        obj["timestamp"] = now_iso_utc()
    obj["from"] = from_branch
    return obj


def append_local_announcements(log_file: pathlib.Path, announcements: Iterable[str], from_branch: str) -> None:
    log_file.parent.mkdir(parents=True, exist_ok=True)
    lock_file = log_file.with_suffix(log_file.suffix + ".lock")
    with lock_file.open("a", encoding="utf-8") as lock:
        fcntl.flock(lock.fileno(), fcntl.LOCK_EX)
        try:
            with log_file.open("a", encoding="utf-8") as f:
                for raw in announcements:
                    obj = normalize_announcement(raw, from_branch)
                    f.write(json.dumps(obj, separators=(",", ":")) + "\n")
                f.flush()
                os.fsync(f.fileno())
        finally:
            fcntl.flock(lock.fileno(), fcntl.LOCK_UN)


def cursor_key_for_path(path: pathlib.Path) -> str:
    digest = hashlib.sha1(str(path).encode("utf-8")).hexdigest()[:16]
    return f"cursor_{digest}"


def load_state(state_file: pathlib.Path) -> Dict[str, int]:
    if not state_file.is_file():
        return {}
    try:
        data = json.loads(state_file.read_text(encoding="utf-8"))
    except Exception:
        return {}
    if not isinstance(data, dict):
        return {}
    cursors = data.get("cursors", data)
    if not isinstance(cursors, dict):
        return {}

    out: Dict[str, int] = {}
    for k, v in cursors.items():
        if not isinstance(k, str):
            continue
        try:
            i = int(v)
        except Exception:
            continue
        if i >= 0:
            out[k] = i
    return out


def save_state(state_file: pathlib.Path, state: Dict[str, int]) -> None:
    payload = {"version": 1, "cursors": state}
    tmp = state_file.with_suffix(state_file.suffix + ".tmp")
    tmp.write_text(json.dumps(payload, separators=(",", ":"), sort_keys=True) + "\n", encoding="utf-8")
    tmp.replace(state_file)


def read_complete_lines(log_file: pathlib.Path, cursor: int) -> Tuple[bytes, int]:
    with log_file.open("rb") as f:
        f.seek(cursor, os.SEEK_SET)
        payload = f.read()
    if not payload:
        return b"", cursor
    last_newline = payload.rfind(b"\n")
    if last_newline < 0:
        return b"", cursor
    consumed = last_newline + 1
    return payload[:consumed], cursor + consumed


def parse_jsonl_lines(payload: bytes, strict: bool) -> Tuple[List[Dict[str, object]], bool]:
    updates: List[Dict[str, object]] = []
    text = payload.decode("utf-8", errors="replace")
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            if strict:
                return [], False
            entry = {"message": line, "invalid_json": True}
        if not isinstance(entry, dict):
            if strict:
                return [], False
            entry = {"message": line, "invalid_json": True}
        updates.append(entry)
    return updates, True


def read_payload_with_retries(log_file: pathlib.Path, cursor: int, attempts: int = 3) -> Tuple[bytes, int]:
    payload = b""
    new_cursor = cursor
    for i in range(attempts):
        payload, new_cursor = read_complete_lines(log_file, cursor)
        if not payload:
            return b"", cursor
        _, ok = parse_jsonl_lines(payload, strict=True)
        if ok:
            return payload, new_cursor
        if i < attempts - 1:
            time.sleep(0.03)
    return payload, new_cursor


def entry_timestamp(entry: object) -> Optional[dt.datetime]:
    if not isinstance(entry, dict):
        return None
    v = entry.get("timestamp", entry.get("ts"))
    if not isinstance(v, str):
        return None
    try:
        return parse_iso_ts(v)
    except ValueError:
        return None


def filter_by_since(updates: List[Dict[str, object]], since_dt: Optional[dt.datetime]) -> List[Dict[str, object]]:
    if since_dt is None:
        return updates
    out: List[Dict[str, object]] = []
    for row in updates:
        entry: object = row
        maybe_nested = row.get("entry")
        if isinstance(maybe_nested, dict):
            entry = maybe_nested
        ts = entry_timestamp(entry)
        if ts is not None and ts >= since_dt:
            out.append(row)
    return out


@dataclass(frozen=True)
class WorktreeInfo:
    path: pathlib.Path
    branch: str
    git_dir: pathlib.Path

    def aliases(self) -> Set[str]:
        names = {self.path.name}
        if self.branch:
            names.add(self.branch)
            names.add(self.branch.replace("/", "_"))
        return names


def list_worktrees(repo_root: pathlib.Path) -> List[WorktreeInfo]:
    p = run_git(["worktree", "list", "--porcelain"], cwd=repo_root, check=False)
    if p.returncode != 0:
        return []

    out: List[WorktreeInfo] = []
    block: Dict[str, str] = {}

    def flush() -> None:
        nonlocal block
        worktree_path = block.get("worktree")
        if not worktree_path:
            block = {}
            return

        branch = ""
        branch_ref = block.get("branch", "")
        if branch_ref.startswith("refs/heads/"):
            branch = branch_ref[len("refs/heads/") :]

        worktree = pathlib.Path(worktree_path).resolve()
        out.append(WorktreeInfo(path=worktree, branch=branch, git_dir=detect_git_dir(worktree)))
        block = {}

    for raw in p.stdout.splitlines():
        line = raw.strip()
        if not line:
            flush()
            continue
        key, sep, value = line.partition(" ")
        if sep:
            block[key] = value.strip()
        else:
            block[key] = ""
    flush()

    return out


def read_new_entries_from_worktree(
    info: WorktreeInfo,
    state: Dict[str, int],
    peek: bool,
    since_dt: Optional[dt.datetime],
) -> Tuple[List[Dict[str, object]], bool]:
    log_file = info.git_dir / LOG_FILENAME
    if not log_file.is_file():
        return [], False

    cursor_key = cursor_key_for_path(info.git_dir)
    cursor = 0
    if since_dt is None:
        cursor = state.get(cursor_key, 0)
        size = log_file.stat().st_size
        if cursor < 0 or cursor > size:
            cursor = 0

    payload, new_cursor = read_payload_with_retries(log_file, cursor)
    if not payload:
        return [], False

    updates, ok = parse_jsonl_lines(payload, strict=True)
    if not ok:
        updates, _ = parse_jsonl_lines(payload, strict=False)

    updates = filter_by_since(updates, since_dt)

    state_changed = False
    if since_dt is None and not peek:
        prev = state.get(cursor_key)
        if prev != new_cursor:
            state[cursor_key] = new_cursor
            state_changed = True

    return updates, state_changed


def read_other_agents(
    current_repo_root: pathlib.Path,
    all_worktrees: List[WorktreeInfo],
    from_agents: Set[str],
    state: Dict[str, int],
    peek: bool,
    since_dt: Optional[dt.datetime],
) -> Tuple[List[Dict[str, object]], bool]:
    out: List[Dict[str, object]] = []
    state_changed = False

    for info in sorted(all_worktrees, key=lambda x: (x.branch, str(x.path))):
        if info.path == current_repo_root:
            continue
        if from_agents and not (info.aliases() & from_agents):
            continue
        updates, changed = read_new_entries_from_worktree(info, state=state, peek=peek, since_dt=since_dt)
        out.extend(updates)
        state_changed = state_changed or changed

    return out, state_changed


def main(argv: List[str]) -> int:
    args = parse_cli(argv)
    cwd = pathlib.Path.cwd().resolve()
    repo_root = detect_repo_root(cwd)
    git_dir = detect_git_dir(cwd)
    branch = detect_branch(cwd)

    if args.announcements:
        append_local_announcements(git_dir / LOG_FILENAME, args.announcements, branch)

    state_file = repo_root / STATE_FILENAME
    state = load_state(state_file)

    from_agents = normalize_from_agents(args.from_agents)
    all_worktrees = list_worktrees(repo_root)
    updates, state_changed = read_other_agents(
        repo_root,
        all_worktrees,
        from_agents=from_agents,
        state=state,
        peek=args.peek,
        since_dt=args.since_dt,
    )
    for row in updates:
        sys.stdout.write(json.dumps(row, separators=(",", ":")))
        sys.stdout.write("\n")

    if state_changed:
        save_state(state_file, state)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
