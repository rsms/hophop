#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
import pathlib
import re
import subprocess
import sys
import time
from typing import Dict, Iterable, List, Optional, Set, Tuple


def run_git(args: List[str], check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", *args],
        check=check,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )


def detect_agent_name(cwd: pathlib.Path) -> str:
    for part in reversed(cwd.parts):
        if re.fullmatch(r"w\d+", part):
            return part
    p = run_git(["branch", "--show-current"], check=False)
    branch = p.stdout.strip()
    m = re.search(r"(w\d+)", branch)
    if m:
        return m.group(1)
    if branch:
        return branch.replace("/", "_")
    return cwd.name


def now_iso_utc() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_iso_ts(value: str) -> dt.datetime:
    v = value.strip()
    if v.endswith("Z"):
        d = dt.datetime.fromisoformat(v[:-1])
        if d.tzinfo is None:
            d = d.replace(tzinfo=dt.timezone.utc)
    else:
        d = dt.datetime.fromisoformat(v)
    if d.tzinfo is None:
        d = d.replace(tzinfo=dt.timezone.utc)
    return d.astimezone(dt.timezone.utc)


def parse_cli(argv: List[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Append local worklog announcements and read updates from sibling worktrees.")
    p.add_argument("--peek", action="store_true", help="Read updates without advancing git-config read cursors.")
    p.add_argument("--since", metavar="TIMESTAMP", help="Read all messages since ISO timestamp (e.g. 2026-02-21T20:00:00Z).")
    p.add_argument("--from", dest="from_agents", action="append", default=[], metavar="wN",
                   help="Only read updates from specific agent worktree name(s). Repeatable; also accepts comma-separated list.")
    p.add_argument("announcements", nargs="*", help="Announcement text or JSON object.")
    args = p.parse_args(argv)
    if args.since:
        try:
            args.since_dt = parse_iso_ts(args.since)
        except ValueError:
            p.error(f"invalid --since timestamp: {args.since!r}")
    else:
        args.since_dt = None
    return args


def normalize_from_agents(values: List[str]) -> Set[str]:
    out: Set[str] = set()
    for raw in values:
        for token in raw.split(","):
            name = token.strip()
            if name:
                out.add(name)
    return out


def normalize_announcement(raw: str) -> Dict[str, object]:
    try:
        obj = json.loads(raw)
        if not isinstance(obj, dict):
            raise ValueError("announcement must be a JSON object")
    except Exception:
        obj = {"message": raw}
    if "timestamp" not in obj and "ts" not in obj:
        obj["timestamp"] = now_iso_utc()
    return obj


def append_local_announcements(log_file: pathlib.Path, announcements: Iterable[str]) -> None:
    log_file.parent.mkdir(parents=True, exist_ok=True)
    with log_file.open("a", encoding="utf-8") as f:
        for raw in announcements:
            obj = normalize_announcement(raw)
            f.write(json.dumps(obj, separators=(",", ":")) + "\n")


def git_config_get(key: str) -> str:
    p = run_git(["config", "--worktree", "--get", key], check=False)
    if p.returncode != 0:
        return ""
    return p.stdout.strip()


def git_config_set(key: str, value: str) -> None:
    run_git(["config", "--worktree", key, value], check=True)


def read_complete_lines(log_file: pathlib.Path, cursor: int) -> Tuple[bytes, int]:
    with log_file.open("rb") as f:
        f.seek(cursor, os.SEEK_SET)
        payload = f.read()
    if not payload:
        return b"", cursor
    last_newline = payload.rfind(b"\n")
    if last_newline < 0:
        return b"", cursor
    consumed = last_newline + 1
    return payload[:consumed], cursor + consumed


def parse_jsonl_lines(agent: str, payload: bytes, strict: bool) -> Tuple[List[Dict[str, object]], bool]:
    updates: List[Dict[str, object]] = []
    text = payload.decode("utf-8", errors="replace")
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            if strict:
                return [], False
            entry = {"message": line, "invalid_json": True}
        updates.append({"from": agent, "entry": entry})
    return updates, True


def read_payload_with_retries(log_file: pathlib.Path, cursor: int, attempts: int = 3) -> Tuple[bytes, int]:
    payload = b""
    new_cursor = cursor
    for i in range(attempts):
        payload, new_cursor = read_complete_lines(log_file, cursor)
        if not payload:
            return b"", cursor
        _, ok = parse_jsonl_lines("", payload, strict=True)
        if ok:
            return payload, new_cursor
        if i < attempts - 1:
            time.sleep(0.03)
    return payload, new_cursor


def entry_timestamp(entry: object) -> Optional[dt.datetime]:
    if not isinstance(entry, dict):
        return None
    v = entry.get("timestamp", entry.get("ts"))
    if not isinstance(v, str):
        return None
    try:
        return parse_iso_ts(v)
    except ValueError:
        return None


def filter_by_since(updates: List[Dict[str, object]], since_dt: Optional[dt.datetime]) -> List[Dict[str, object]]:
    if since_dt is None:
        return updates
    out: List[Dict[str, object]] = []
    for row in updates:
        ts = entry_timestamp(row.get("entry"))
        if ts is not None and ts >= since_dt:
            out.append(row)
    return out


def read_new_entries_from_agent(
    current_agent: str,
    sibling_dir: pathlib.Path,
    peek: bool,
    since_dt: Optional[dt.datetime],
) -> List[Dict[str, object]]:
    agent = sibling_dir.name
    log_file = sibling_dir / "agent-worklog.jsonl"
    if agent == current_agent or not log_file.is_file():
        return []

    cfg_key = f"custom.agent_log.{agent}"
    cursor = 0
    if since_dt is None:
        cursor_raw = git_config_get(cfg_key)
        try:
            cursor = int(cursor_raw) if cursor_raw else 0
        except ValueError:
            cursor = 0
        size = log_file.stat().st_size
        if cursor < 0 or cursor > size:
            cursor = 0

    payload, new_cursor = read_payload_with_retries(log_file, cursor)
    if not payload:
        return []

    updates, ok = parse_jsonl_lines(agent, payload, strict=True)
    if not ok:
        updates, _ = parse_jsonl_lines(agent, payload, strict=False)

    updates = filter_by_since(updates, since_dt)

    if since_dt is None and not peek:
        git_config_set(cfg_key, str(new_cursor))
    return updates


def read_other_agents(
    current_agent: str,
    cwd: pathlib.Path,
    from_agents: Set[str],
    peek: bool,
    since_dt: Optional[dt.datetime],
) -> List[Dict[str, object]]:
    parent = cwd.parent
    out: List[Dict[str, object]] = []
    for sibling in sorted(parent.glob("w[0-9]*")):
        if sibling.is_dir():
            if from_agents and sibling.name not in from_agents:
                continue
            out.extend(read_new_entries_from_agent(current_agent, sibling, peek=peek, since_dt=since_dt))
    return out


def main(argv: List[str]) -> int:
    args = parse_cli(argv)
    cwd = pathlib.Path.cwd().resolve()
    agent = detect_agent_name(cwd)

    if args.announcements:
        append_local_announcements(cwd / "agent-worklog.jsonl", args.announcements)

    from_agents = normalize_from_agents(args.from_agents)
    updates = read_other_agents(agent, cwd, from_agents=from_agents, peek=args.peek, since_dt=args.since_dt)
    for row in updates:
        sys.stdout.write(json.dumps(row, separators=(",", ":")))
        sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
