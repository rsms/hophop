// Verifies string format nonconst arguments is accepted.
fn str_eq(got, want &str) bool {
	if len(got) != len(want) {
		return false
	}
	var gotBytes  &[u8] = got
	var wantBytes &[u8] = want
	for var i int = 0; i < len(want); i += 1 {
		if gotBytes[i] != wantBytes[i] {
			return false
		}
	}
	return true
}

fn main() {
	var a   i64  = 42
	var b   f64  = 3.5
	var s   &str = "hi"
	var out *str = format("i={}, f={f}, s={s}", a, b, s)
	assert str_eq(out, want: "i=42, f=3.5, s=hi")
	del out
}
