#include <stddef.h>

#include "@HEADER@"

typedef void (*expected_logger_handler_t)(__hop_Logger*, __hop_str, __hop_LogLevel, __hop_LogFlags);

_Static_assert(offsetof(__hop_str, ptr) == 0, "__hop_str.ptr must be first field");
_Static_assert(sizeof(((__hop_str*)0)->ptr) == sizeof(__hop_u8*), "__hop_str.ptr must be __hop_u8*");
_Static_assert(
    sizeof(((__hop_str*)0)->len) == sizeof(__hop_int), "__hop_str.len must be __hop_int");
_Static_assert(
    offsetof(__hop_str, len) == sizeof(__hop_u8*),
    "__hop_str.len offset must match pointer-sized fat pointer layout");
_Static_assert(
    _Generic(((__hop_Logger){0}).handler, expected_logger_handler_t: 1, default: 0),
    "__hop_Logger.handler must use __hop_str in ABI");
_Static_assert(
    _Generic(((__hop_Logger){0}).prefix, __hop_str: 1, default: 0),
    "__hop_Logger.prefix must be __hop_str in ABI");
_Static_assert(
    _Generic(__hop_strlit("x"), const __hop_str*: 1, default: 0),
    "__hop_strlit must produce const __hop_str*");
