// Verifies string format basic is accepted.
fn str_eq(got, want &str) bool {
	if len(got) != len(want) {
		return false
	}
	var gotBytes  &[u8] = got
	var wantBytes &[u8] = want
	for var i int = 0; i < len(want); i += 1 {
		if gotBytes[i] != wantBytes[i] {
			return false
		}
	}
	return true
}

fn main() {
	var s *str = format("i={i}, f={}, s={s}, braces={{ok}}", 42 as i64, 3.5 as f64, "hi")
	assert str_eq(s, want: "i=42, f=3.5, s=hi, braces={ok}")
	del s
}
