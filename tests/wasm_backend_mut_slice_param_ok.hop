fn swap_first_two(values *[i32]) {
	assert len(values) == 3
	var tmp i32 = values[0]
	values[0] = values[1]
	values[1] = tmp
}

fn main() {
	var values [i32 3]
	values[0] = 10
	values[1] = 20
	values[2] = 30

	swap_first_two(values[:])

	assert values[0] == 20
	assert values[1] == 10
	assert values[2] == 30
}
