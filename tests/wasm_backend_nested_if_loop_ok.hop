fn main() {
	var prime [bool 10]

	for var i i32 = 2; i <= 9; i += 1 {
		prime[i] = true
	}

	for var p i32 = 2; p * p <= 9; p += 1 {
		if prime[p] {
			for var multiple i32 = p * p; multiple <= 9; multiple += p {
				prime[multiple] = false
			}
		}
	}

	assert prime[2]
	assert prime[3]
	assert !prime[4]
	assert prime[5]
	assert !prime[6]
	assert prime[7]
	assert !prime[8]
	assert !prime[9]
}
