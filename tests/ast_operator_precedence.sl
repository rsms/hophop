	a * obj.field
	// postfix-right 143: (obj.field) with /
	a / obj.field
	// postfix-right 144: (obj.field) with %
	a % obj.field
	// postfix-right 145: ((a) as int) with =
	a = (a) as int
	// postfix-right 146: ((a) as int) with +=
	a += (a) as int
	// postfix-right 147: ((a) as int) with -=
	a -= (a) as int
	// postfix-right 148: ((a) as int) with *=
	a *= (a) as int
	// postfix-right 149: ((a) as int) with /=
	a /= (a) as int
	// postfix-right 150: ((a) as int) with %=
	a %= (a) as int
	// postfix-right 151: ((a) as int) with &=
	a &= (a) as int
	// postfix-right 152: ((a) as int) with |=
	a |= (a) as int
	// postfix-right 153: ((a) as int) with ^=
	a ^= (a) as int
	// postfix-right 154: ((a) as int) with <<=
	a <<= (a) as int
