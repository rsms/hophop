	a == (a) as int
	// postfix-right 159: ((a) as int) with !=
	a != (a) as int
	// postfix-right 160: ((a) as int) with <
	a < (a) as int
	// postfix-right 161: ((a) as int) with <=
	a <= (a) as int
	// postfix-right 162: ((a) as int) with >
	a > (a) as int
	// postfix-right 163: ((a) as int) with >=
	a >= (a) as int
	// postfix-right 164: ((a) as int) with |
	a | (a) as int
	// postfix-right 165: ((a) as int) with ^
	a ^ (a) as int
	// postfix-right 166: ((a) as int) with +
	a + (a) as int
	// postfix-right 167: ((a) as int) with -
	a - (a) as int
	// postfix-right 168: ((a) as int) with &
	a & (a) as int
	// postfix-right 169: ((a) as int) with <<
	a << (a) as int
	// postfix-right 170: ((a) as int) with >>
	a >> (a) as int
	// postfix-right 171: ((a) as int) with *
	a * (a) as int
	// postfix-right 172: ((a) as int) with /
	a / (a) as int
	// postfix-right 173: ((a) as int) with %
	a % (a) as int
	// postfix-right 174: (opt!) with =
	a = opt!
	// postfix-right 175: (opt!) with +=
	a += opt!
	// postfix-right 176: (opt!) with -=
	a -= opt!
	// postfix-right 177: (opt!) with *=
	a *= opt!
	// postfix-right 178: (opt!) with /=
	a /= opt!
	// postfix-right 179: (opt!) with %=
	a %= opt!
	// postfix-right 180: (opt!) with &=
	a &= opt!
	// postfix-right 181: (opt!) with |=
	a |= opt!
	// postfix-right 182: (opt!) with ^=
	a ^= opt!
	// postfix-right 183: (opt!) with <<=
	a <<= opt!
	// postfix-right 184: (opt!) with >>=
	a >>= opt!
	// postfix-right 185: (opt!) with ||
	a || opt!
	// postfix-right 186: (opt!) with &&
	a && opt!
	// postfix-right 187: (opt!) with ==
	a == opt!
	// postfix-right 188: (opt!) with !=
	a != opt!
	// postfix-right 189: (opt!) with <
	a < opt!
	// postfix-right 190: (opt!) with <=
	a <= opt!
	// postfix-right 191: (opt!) with >
	a > opt!
	// postfix-right 192: (opt!) with >=
	a >= opt!
	// postfix-right 193: (opt!) with |
	a | opt!
	// postfix-right 194: (opt!) with ^
	a ^ opt!
	// postfix-right 195: (opt!) with +
	a + opt!
	// postfix-right 196: (opt!) with -
	a - opt!
	// postfix-right 197: (opt!) with &
	a & opt!
	// postfix-right 198: (opt!) with <<
	a << opt!
	// postfix-right 199: (opt!) with >>
	a >> opt!
	// postfix-right 200: (opt!) with *
	a * opt!
	// postfix-right 201: (opt!) with /
	a / opt!
	// postfix-right 202: (opt!) with %
	a % opt!

	// Mixed prefix+postfix nesting probes.
	*ptr + arr[0]
	&a == obj.field
	!(p && q) || opt! != null
	(a + b) as int << c
}
