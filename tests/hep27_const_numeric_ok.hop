// Verifies HEP 27 const numeric is accepted.
fn add1(const x const_int) const_int {
	return x + 1
}

fn takes_int(x int) {
	_ = x
}

fn takes_f64(x f64) {
	_ = x
}

fn main() {
	const ci const_int   = add1(100)
	const cf const_float = 100.5

	var as_u8  u8  = ci
	var as_i16 i16 = 'A'
	var as_f32 f32 = ci
	var as_f64 f64 = cf

	inferred_int := 1
	inferred_float := 1.0
	inferred_from_rune := 'Z'

	takes_int(inferred_int)
	takes_f64(inferred_float)
	takes_int(inferred_from_rune)

	_ = as_u8
	_ = as_i16
	_ = as_f32
	_ = as_f64
}
