// Supports nested type import alias by providing the app entrypoint.
import "lib/coll" as coll

fn is_one(t coll.Collection.Tag) bool {
	return t == coll.Collection.Tag.One
}

fn main() {
	c := coll.Collection{}
	v := coll.Collection.Value{ i: 7 }
	it := coll.Collection.Item{ parent: &c, value: v }
	assert it.value.i == 7
	assert is_one(coll.Collection.Tag.One)
}
