import "playbit/event"  { poll }
import "playbit/signal" { observe }
import "playbit/window" { main as main_window, scale, set_title }

fn main() {
	var w = main_window()
	if w > 0 {
		_ = observe(w, signals: 1 | 4)
		_ = set_title(w, title: "hop playbit smoke")
		assert scale(w) > 0 as f32
	}

	var buffer [u8 256]
	var count = poll(buffer[:], deadline: 0, leeway: 0)
	assert count >= 0
}
