// Verifies reflection can distinguish const-evaluable arguments.
import "builtin"

fn expect_const(x anytype) {
	const {
		assert is_const(x)
	}
}

fn expect_non_const(x anytype) {
	const {
		assert !is_const(x)
	}
}

fn main() {
	var s &str = "hello"
	expect_const("hello")
	expect_non_const(s)

	var k builtin.TypeKind = kind(ptr(i32))
	assert k as u8 == 6
}
