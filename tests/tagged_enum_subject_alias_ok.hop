// Verifies tagged enum subject alias is accepted.
enum Token u8 {
	End
	Int struct {
		value i32
	}
}

fn next() Token {
	return Token.Int{ value: 4 }
}

fn read() i32 {
	switch next() {
		case Token.End      { return 0 }
		case Token.Int as t { return t.value }
	}
}

fn main() {
	assert read() == 4
}
