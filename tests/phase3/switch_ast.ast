FILE [0,160]
  FN "classify" [0,159]
    PARAM "x" [12,17]
      TYPE_NAME "i32" [14,17]
    TYPE_NAME flags=1 "i32" [19,22]
    BLOCK [23,159]
      SWITCH flags=1 [29,157]
        IDENT "x" [36,37]
        CASE [44,75]
          INT "0" [49,50]
          BLOCK [51,75]
            RETURN [61,69]
              INT "0" [68,69]
        CASE [80,114]
          INT "1" [85,86]
          INT "2" [88,89]
          BLOCK [90,114]
            RETURN [100,108]
              INT "1" [107,108]
        DEFAULT [119,151]
          BLOCK [127,151]
            RETURN [137,145]
              INT "2" [144,145]
