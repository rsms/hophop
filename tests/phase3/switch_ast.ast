FILE [0,174]
  PACKAGE "demo" [0,12]
  FN "classify" [14,173]
    PARAM "x" [26,31]
      TYPE_NAME "i32" [28,31]
    TYPE_NAME flags=1 "i32" [33,36]
    BLOCK [37,173]
      SWITCH flags=1 [43,171]
        IDENT "x" [50,51]
        CASE [58,89]
          INT "0" [63,64]
          BLOCK [65,89]
            RETURN [75,83]
              INT "0" [82,83]
        CASE [94,128]
          INT "1" [99,100]
          INT "2" [102,103]
          BLOCK [104,128]
            RETURN [114,122]
              INT "1" [121,122]
        DEFAULT [133,165]
          BLOCK [141,165]
            RETURN [151,159]
              INT "2" [158,159]
