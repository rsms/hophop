// Verifies evaluator runtime can indirectly call a handler field on a returned allocator value.
struct MyMemAllocator {
	calls int
	slot  i32
}

fn handler(ma *MemAllocator, addr rawptr, align, curSize int, newSize *int, flags u32, srcLoc SourceLocation) rawptr {
	self := ma.data as *MyMemAllocator
	p := &self.slot
	self.calls += 1
	return p as rawptr
}

fn allocator(self *MyMemAllocator) MemAllocator {
	h := handler
	return { handler: h, data: self as rawptr }
}

fn main() {
	ma := MyMemAllocator{}
	out := ma.allocator()

	addr := null as rawptr
	align := 4
	curSize := 0
	newSize := 4
	flags := 0 as u32
	srcLoc := SourceLocation{}
	p := out.handler(&out, addr, align, curSize, newSize: &newSize, flags, srcLoc)
	assert p != null
	assert ma.calls == 1
	print("handler called")
}
