// Verifies rejected method overload instances do not poison const-parameter forwarding.
fn validate(const fmt &str, args ...anytype) {
	const {
		assert len(fmt) == 4
		assert len(args) == 1
	}
}

fn format(const fmt &str, args ...anytype) int {
	validate(fmt, args...)
	return len(fmt)
}

fn format(buf *[u8], const fmt &str, args ...anytype) int {
	validate(fmt, args...)
	return len(buf) + len(fmt)
}

fn main() {
	var msg [u8 128]
	assert msg.format("x={}", 123) == 132
	assert format("z={}", 1) == 4
}
