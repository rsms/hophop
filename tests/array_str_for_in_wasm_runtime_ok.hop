// Verifies direct Wasm support for inferred fixed arrays of str.
fn write_line(message &str) {
	print(message)
}

fn main() {
	greetings := [
		"Hej världen!"
		"Hello, world!"
		"¡Hola Mundo!"
		"Γειά σου Κόσμε!"
		"Привіт, світе!"
		"こんにちは世界！"
	]
	for greeting in greetings {
		write_line(greeting)
	}
}
