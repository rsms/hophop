fn bubble_sort(values *[int]) {
	for n := len(values); n > 1; n -= 1 {
		changed := false
		for i := 1; i < n; i += 1 {
			if values[i - 1] > values[i] {
				values[i], values[i - 1] = values[i - 1], values[i]
				changed = true
			}
		}
		if !changed {
			break
		}
	}
}

fn main() {
	values := [5, 1, 4, 2, 8, 0, -3, 7]
	bubble_sort(values)
	for value in values {
		print(value)
	}
}
