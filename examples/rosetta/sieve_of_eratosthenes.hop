const limit = 100

fn main() {
	var primes [bool limit - 1]

	for p := 2; p * p <= limit; p += 1 {
		if !primes[p - 2] {
			for multiple := p * p; multiple <= limit; multiple += p {
				primes[multiple - 2] = true
			}
		}
	}

	for i := 0; i < limit - 1; i += 1 {
		if !primes[i] {
			var buf [u8 24]
			n := buf.format("{}", i + 2)
			print(buf[:n] as &str)
		}
	}
}
