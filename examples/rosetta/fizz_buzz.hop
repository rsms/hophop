		platform.console_log("47", flags: 0)
	} else if n == 49 {
		platform.console_log("49", flags: 0)
	} else if n == 52 {
		platform.console_log("52", flags: 0)
	} else if n == 53 {
		platform.console_log("53", flags: 0)
	} else if n == 56 {
		platform.console_log("56", flags: 0)
	} else if n == 58 {
