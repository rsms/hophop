	} else if n == 98 {
		platform.console_log("98", flags: 0)
	} else {
		assert false
	}
}

fn main() {
	var fizz i32 = 0
	var buzz i32 = 0
	for var i i32 = 1; i <= 100; i += 1 {
		fizz += 1
		buzz += 1

		if fizz == 3 && buzz == 5 {
			platform.console_log("FizzBuzz", flags: 0)
			fizz = 0
			buzz = 0
		} else if fizz == 3 {
			platform.console_log("Fizz", flags: 0)
			fizz = 0
		} else if buzz == 5 {
			platform.console_log("Buzz", flags: 0)
			buzz = 0
		} else {
			print_number(i)
		}
	}
}
