import "platform"

fn print_number(n i32) {
	if n == 1 {
		platform.console_log("1", flags: 0)
	} else if n == 2 {
		platform.console_log("2", flags: 0)
	} else if n == 4 {
		platform.console_log("4", flags: 0)
	} else if n == 7 {
		platform.console_log("7", flags: 0)
	} else if n == 8 {
